# BlockQuant pre-baked RunPod image — Qwen3.5 variant.
#
# Bakes exllamav3 c5d9c65 (0.0.43) + flash-linear-attention for the qwen3_5 /
# qwen3_5_moe linear (gated-delta) attention path (gdn.cu + fla ops). Routed to
# ONLY those archs by run_runpod_job.py; proven models stay on Dockerfile.runpod.
#
# **Python 3.12** is load-bearing here. fla 0.5.1's triton kernels trip triton
# bug #5224 (multi-decorator @triton.jit -> inspect.getsource returns only the
# decorators -> `import fla` AttributeError) on Python 3.11, but NOT on 3.12
# (different inspect/tokenize). Verified on a GPU pod: py3.11 fails, py3.12
# imports fla cleanly. So ubuntu24.04 (native py3.12), torch 2.8/cu129, and
# triton stays at its native 3.4.0 (no downgrade — the bug was python, not triton).
# flash-attn is intentionally NOT installed (SDPA is fine for quant calibration);
# patch_flash_attn.py keeps exllamav3 importing without it.

# ---- Base (ubuntu24.04 -> Python 3.12) ------------------------------------
FROM nvidia/cuda:12.9.1-cudnn-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.12 python3.12-dev python3-pip \
        git wget ca-certificates \
        ninja-build build-essential \
        openssh-server \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/run/sshd \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1 \
    && rm -f /usr/lib/python3.12/EXTERNALLY-MANAGED

# ---- torch 2.8 / cu129 (pip auto-selects the cp312 wheel) ------------------
RUN python -m pip install \
        "torch==2.8.0" \
        --index-url https://download.pytorch.org/whl/cu129

# ---- Python deps ----------------------------------------------------------
RUN python -m pip install \
        "hf_transfer>=0.1.6" \
        "huggingface-hub>=0.21" \
        "transformers>=4.45.0,<5" \
        "tokenizers>=0.21.1" \
        "safetensors>=0.4" \
        "datasets>=2.0" \
        "numpy>=2.1.0" \
        "Pillow>=10.0" \
        "marisa-trie>=1.2" \
        "pydantic==2.11.0" \
        "kbnf>=0.4.2" \
        "formatron>=0.5.0" \
        "rich>=13.0" \
        "tqdm" \
        "psutil" \
        "sentencepiece" \
        "pyyaml" \
        "typing_extensions" \
        "einops"

# ---- ExLlamaV3 0.0.43 -----------------------------------------------------
# EXLLAMA_NOCOMPILE: install without building the CUDA ext (the GPU-less CI
# builder can't auto-detect an arch -> _get_cuda_arch_flags IndexError). The
# ext JIT-builds on the pod's first boot (GPU + ninja present).
ARG EXLLAMAV3_REF=c5d9c65
RUN EXLLAMA_NOCOMPILE=1 python -m pip install --no-cache-dir --no-deps \
        "exllamav3 @ git+https://github.com/turboderp-org/exllamav3@${EXLLAMAV3_REF}"

# ---- flash-linear-attention (the qwen3_5 gated-delta-net path) ------------
# Required by exllamav3 0.0.43 for linear-attention archs. Bare install — FLA
# 0.5.x no longer pulls torch/triton, so it uses the baked torch-2.8 + its native
# triton 3.4.0 (which imports fine under python 3.12).
RUN python -m pip install --no-cache-dir "flash-linear-attention>=0.5.0"

# ---- Make exllamav3 import without flash-attn (not installed here) ---------
COPY docker/patch_flash_attn.py /tmp/patch_flash_attn.py
RUN python /tmp/patch_flash_attn.py && rm /tmp/patch_flash_attn.py
COPY docker/patch_attn_reshape.py /tmp/patch_attn_reshape.py
RUN python /tmp/patch_attn_reshape.py && rm /tmp/patch_attn_reshape.py

# ---- Bundled calibration corpus ------------------------------------------
COPY docker/fetch_cal_data.py /tmp/fetch_cal_data.py
RUN python /tmp/fetch_cal_data.py && rm /tmp/fetch_cal_data.py

# ---- Stub formatron (quant-only image) ------------------------------------
COPY docker/stub_formatron.py /tmp/stub_formatron.py
RUN python /tmp/stub_formatron.py && rm /tmp/stub_formatron.py

# ---- Verify the stack at build time ---------------------------------------
# Hard-assert python 3.12 + torch 2.8 (the combo that makes `import fla` work).
RUN python - <<'PY'
import sys, torch, importlib.metadata as m
assert sys.version_info[:2] == (3, 12), f"need python 3.12, got {sys.version}"
assert torch.__version__.startswith("2.8"), f"torch not 2.8: {torch.__version__}"
print("python", sys.version.split()[0], "| torch", torch.__version__,
      "| triton", m.version("triton"), "| fla", m.version("flash-linear-attention"),
      "| exllamav3", m.version("exllamav3"), "| transformers", m.version("transformers"))
PY
# `import fla` parses triton kernels (CPU) then inits the CUDA driver. On the
# GPU-less builder it must REACH the driver init -- proving the #5224 parse bug
# is gone under py3.12. The driver error is expected here (satisfied on the pod);
# the parse AttributeError (the py3.11 failure) would fail the build instead.
RUN python - <<'PY'
try:
    import fla
    print("FLA IMPORT OK (gpu driver present)")
except RuntimeError as e:
    assert "driver" in str(e).lower(), f"unexpected fla import error: {e!r}"
    print("FLA parse OK; reached GPU driver init (expected GPU-less on CI):", e)
PY
# exllamav3's CUDA ext JITs on import (ninja present) -> best-effort GPU-less.
RUN python -c "import exllamav3; print('exllamav3 import ok')" \
    || echo "(exllamav3 import deferred to pod -- needs GPU/JIT)"

# ---- BlockQuant remote entrypoint ----------------------------------------
RUN mkdir -p /opt/blockquant
COPY backend/src/blockquant/remote/quant.py /opt/blockquant/quant.py
COPY backend/src/blockquant/cards.py /opt/blockquant/cards.py
COPY backend/templates/card_template.md /opt/blockquant/card_template.md
COPY docker/entrypoint.sh /opt/blockquant/entrypoint.sh
RUN chmod +x /opt/blockquant/entrypoint.sh /opt/blockquant/quant.py

LABEL org.opencontainers.image.title="BlockQuant RunPod Qwen3.5" \
      org.opencontainers.image.description="exllamav3 0.0.43 + flash-linear-attention on python 3.12; qwen3_5/qwen3_5_moe only." \
      org.opencontainers.image.source="https://github.com/Honkware/blockquant" \
      org.opencontainers.image.licenses="MIT" \
      blockquant.exllamav3_ref="${EXLLAMAV3_REF}" \
      blockquant.python_version="3.12" \
      blockquant.torch_version="2.8.0+cu129" \
      blockquant.cuda_runtime="12.9.1"

WORKDIR /workspace
EXPOSE 22
CMD ["/opt/blockquant/entrypoint.sh"]
