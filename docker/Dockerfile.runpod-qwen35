# BlockQuant pre-baked RunPod image — Qwen3.5 variant.
#
# Same shape as Dockerfile.runpod but bakes exllamav3 c5d9c65 (0.0.43) on a
# torch-2.8/cu129 base + flash-linear-attention, which 0.0.43 needs for the
# qwen3_5 / qwen3_5_moe linear (gated-delta) attention path (gdn.cu + fla ops).
# run_runpod_job.py routes ONLY those archs here; every proven model stays on
# Dockerfile.runpod (0.0.38), since 0.0.43 regresses them (e.g. Qwen3.6).
#
# Why a separate file/base: flash-linear-attention 0.5.x needs torch>=2.7, so it
# cannot be built on Dockerfile.runpod's torch-2.6/cu124 base. flash-attn is
# intentionally NOT installed (SDPA is adequate for quant calibration, as in the
# default bootstrap path); patch_flash_attn.py keeps exllamav3 importing without it.

# ---- Base ----------------------------------------------------------------
FROM nvidia/cuda:12.9.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-dev python3-pip \
        git wget ca-certificates \
        ninja-build build-essential \
        openssh-server \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/run/sshd \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
    && python -m pip install --upgrade pip

# ---- torch 2.8 / cu129 (flash-linear-attention needs torch>=2.7) ----------
RUN python -m pip install \
        "torch==2.8.0" \
        --index-url https://download.pytorch.org/whl/cu129

# ---- Python deps ----------------------------------------------------------
# transformers>=4.45 + numpy>=2.1 are exllamav3 0.0.43 / FLA floors; the rest
# mirror Dockerfile.runpod.
RUN python -m pip install \
        "hf_transfer>=0.1.6" \
        "huggingface-hub>=0.21" \
        "transformers>=4.45.0,<5" \
        "tokenizers>=0.21.1" \
        "safetensors>=0.4" \
        "datasets>=2.0" \
        "numpy>=2.1.0" \
        "Pillow>=10.0" \
        "marisa-trie>=1.2" \
        "pydantic==2.11.0" \
        "kbnf>=0.4.2" \
        "formatron>=0.5.0" \
        "rich>=13.0" \
        "tqdm" \
        "psutil" \
        "sentencepiece" \
        "pyyaml" \
        "typing_extensions" \
        "einops"

# ---- ExLlamaV3 0.0.43 -----------------------------------------------------
# --no-deps as on the proven image (its metadata hard-requires flash-attn/
# xformers; we own those paths). The qwen3_5 fixes + gdn.cu kernels are in this
# commit. Bump behind an end-to-end Qwen3.5 pass.
ARG EXLLAMAV3_REF=c5d9c65
RUN python -m pip install --no-cache-dir --no-deps \
        "exllamav3 @ git+https://github.com/turboderp-org/exllamav3@${EXLLAMAV3_REF}"

# ---- flash-linear-attention (the qwen3_5 gated-delta-net path) ------------
# Required by exllamav3 0.0.43 for linear-attention archs (fla.ops.gated_delta_rule).
# Bare install — FLA 0.5.x no longer pulls torch/triton, so it uses the baked
# torch-2.8 + its triton and can't move them. Pulls fla-core + transformers.
RUN python -m pip install --no-cache-dir "flash-linear-attention>=0.5.0"

# torch 2.8 ships triton 3.4.0, whose JITFunction source parser (jit.py) chokes
# on fla 0.5.1's autotuned kernels at IMPORT (re.search(...).start() on None ->
# import fla fails). Pin triton 3.3.1, which parses them cleanly. Quant uses
# triton only via fla, never torch.compile, so this is safe under torch 2.8.
RUN python -m pip install --no-cache-dir "triton==3.3.1"

# ---- Make exllamav3 import without flash-attn (not installed here) ---------
COPY docker/patch_flash_attn.py /tmp/patch_flash_attn.py
RUN python /tmp/patch_flash_attn.py && rm /tmp/patch_flash_attn.py
COPY docker/patch_attn_reshape.py /tmp/patch_attn_reshape.py
RUN python /tmp/patch_attn_reshape.py && rm /tmp/patch_attn_reshape.py

# ---- Bundled calibration corpus ------------------------------------------
COPY docker/fetch_cal_data.py /tmp/fetch_cal_data.py
RUN python /tmp/fetch_cal_data.py && rm /tmp/fetch_cal_data.py

# ---- Stub formatron (quant-only image) ------------------------------------
COPY docker/stub_formatron.py /tmp/stub_formatron.py
RUN python /tmp/stub_formatron.py && rm /tmp/stub_formatron.py

# ---- Verify the stack at build time (CPU-only) ----------------------------
# Hard-assert torch stayed 2.8/cu129 (FLA must NOT have moved it) and that the
# fla gated-delta op the qwen3_5 path needs is importable. exllamav3's CUDA ext
# JITs on import; that needs nvcc (present) but can be flaky GPU-less, so its
# import is guarded and deferred to the pod's first boot if it doesn't compile.
# Hard-verify the stack assembles (CPU-safe): torch stayed 2.8, triton is the
# pinned 3.3.1, and -- the load-bearing check -- `import fla` succeeds, which is
# pure source parsing (no GPU) and was the exact thing failing on the pod.
RUN python - <<'PY'
import torch, importlib.metadata as m
assert torch.__version__.startswith("2.8"), f"torch moved off 2.8: {torch.__version__}"
assert m.version("triton").startswith("3.3"), f"triton not 3.3.x: {m.version('triton')}"
print("torch", torch.__version__, "| triton", m.version("triton"),
      "| fla", m.version("flash-linear-attention"),
      "| exllamav3", m.version("exllamav3"), "| transformers", m.version("transformers"))
# `import fla` decorates triton kernels (parsing -- CPU) then inits the CUDA
# driver. On this GPU-less builder it must reach the driver init: that proves
# the triton-3.4 parse bug is GONE. The driver error is expected here and is
# satisfied on the actual pod; any OTHER error (e.g. the parse AttributeError)
# is a real regression and fails the build.
RUN python - <<'PY'
try:
    import fla
    print("FLA IMPORT OK (gpu driver present)")
except RuntimeError as e:
    assert "driver" in str(e).lower(), f"unexpected fla import error: {e!r}"
    print("FLA parse OK; reached GPU driver init (expected GPU-less on CI):", e)
PY
# exllamav3's CUDA ext JITs on import (needs nvcc; flaky GPU-less) -> best-effort.
RUN python -c "import exllamav3; print('exllamav3 import ok')" \
    || echo "(exllamav3 import deferred to pod -- needs GPU/JIT)"

# ---- BlockQuant remote entrypoint ----------------------------------------
RUN mkdir -p /opt/blockquant
COPY backend/src/blockquant/remote/quant.py /opt/blockquant/quant.py
COPY backend/src/blockquant/cards.py /opt/blockquant/cards.py
COPY backend/templates/card_template.md /opt/blockquant/card_template.md
COPY docker/entrypoint.sh /opt/blockquant/entrypoint.sh
RUN chmod +x /opt/blockquant/entrypoint.sh /opt/blockquant/quant.py

LABEL org.opencontainers.image.title="BlockQuant RunPod Qwen3.5" \
      org.opencontainers.image.description="exllamav3 0.0.43 + flash-linear-attention; qwen3_5/qwen3_5_moe only." \
      org.opencontainers.image.source="https://github.com/Honkware/blockquant" \
      org.opencontainers.image.licenses="MIT" \
      blockquant.exllamav3_ref="${EXLLAMAV3_REF}" \
      blockquant.torch_version="2.8.0+cu129" \
      blockquant.cuda_runtime="12.9.1"

WORKDIR /workspace
EXPOSE 22
CMD ["/opt/blockquant/entrypoint.sh"]
