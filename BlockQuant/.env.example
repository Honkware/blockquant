# ── Discord ───────────────────────────────────────
BOT_TOKEN=
CLIENT_ID=
GUILD_ID=

# ── HuggingFace ──────────────────────────────────
HF_TOKEN=
HF_ORG=               # optional: org name to upload under (leave blank for personal)

# ── Access Control ───────────────────────────────
ADMIN_IDS=             # comma-separated Discord user IDs

# ── Paths ────────────────────────────────────────
WORKSPACE_DIR=./tmp/workdir
EXLLAMAV3_DIR=../exllamav3   # external exllamav3 clone path (can be absolute)

# ── Runtime ──────────────────────────────────────
NODE_ENV=development
CONCURRENT_JOBS=1
SHUTDOWN_TIMEOUT_MS=60000
PROCESS_KILL_GRACE_MS=5000
PYTHON_BIN=

# ── Retry / Timeout Policy ───────────────────────
HF_PREFLIGHT_TIMEOUT_MS=30000
HF_DOWNLOAD_TIMEOUT_MS=3600000
HF_UPLOAD_TIMEOUT_MS=3600000
QUANTIZE_TIMEOUT_MS=43200000
HF_RETRY_MAX_ATTEMPTS=3
HF_RETRY_BASE_DELAY_MS=1500
HF_RETRY_MAX_DELAY_MS=20000
HF_RETRY_JITTER_PCT=25

# ── Cache Policy ─────────────────────────────────
MODEL_CACHE_ENABLED=true
MODEL_CACHE_TTL_HOURS=72
MODEL_CACHE_MAX_ENTRIES=5
MODEL_CACHE_MAX_BYTES=214748364800
MODEL_CACHE_PRUNE_ON_STARTUP=true
MODEL_CACHE_VALIDATE_ON_RESTORE=true

# ── Logging / Security ───────────────────────────
LOG_REDACTION_ENABLED=true
LOG_INCLUDE_STACKS=true
PUBLIC_ERROR_REDACTION_ENABLED=true

# ── Quantization Defaults ────────────────────────
HEAD_BITS=6
