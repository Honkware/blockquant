# Auto-detect text files and normalise line endings to LF in the repo.
# Windows checkouts still see CRLF in the working tree.
* text=auto eol=lf

# Explicit LF for cross-platform shell + Python
*.sh   text eol=lf
*.py   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf

# Binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar.gz binary
*.gguf   binary
*.safetensors binary
*.bin    binary
